#
# Pdel_xy[[1]][[1]][,,1] * Pdel_xy[[2]][[2]][,,2] *
#   Py_x[,,1,2]
#
# Pdel_xy[[1]][[1]][,,2] * Pdel_xy[[2]][[2]][,,2] *
#   Py_x[,,2,2] / (                    Pdel_xy[[1]][[1]][,,2] * Pdel_xy[[2]][[2]][,,2] *
#     Py_x[,,2,2] +                     Pdel_xy[[1]][[1]][,,1] * Pdel_xy[[2]][[2]][,,2] *
#     Py_x[,,1,2])
#
# p_01s_true[[2]][,,2,2,drop = F]
